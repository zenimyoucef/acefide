DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/acefide?schema=public"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ACEFIDE"
AUTH_SECRET="generate-a-long-random-secret"

# Private Vercel Blob store token used only for sensitive membership documents.
BLOB_READ_WRITE_TOKEN=""

# Separate public Blob store token used only by public site media uploads.
PUBLIC_BLOB_READ_WRITE_TOKEN=""

# Used only by `npm run db:seed`; no default administrator is created.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME="ACEFIDE Administrator"

# Reserved for optional email delivery. Submissions currently remain in the admin inbox.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""
